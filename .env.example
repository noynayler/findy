# Copy to .env in the project root (and/or use frontend/.env for VITE_*).
# DEBUG=True
# PORT=5000
#
# --- Supabase (required for Flask job cache + browser) ---
# Backend reads: SUPABASE_* first, else VITE_* from frontend/.env (see backend/database.py).
# Apply postgresql/schema.sql once in the Supabase SQL editor (Flask no longer runs DDL).
#
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# Or reuse the same values as the frontend:
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
#
# --- Job refresh (cron) ---
# Search reads from public.jobs; populate via POST /api/jobs/refresh (or /refresh).
# If set, refresh requires: Authorization: Bearer <secret> OR ?token=<secret>
# JOBS_REFRESH_SECRET=your_long_random_string
